# Ignore specific files and folders
**/.env
**/.env.*
!**/.env.example
**/*.csv
**/*.jsonl

# Explicitly ignore ALL model files first (Safety net)
**/*.pt
**/*.pth
*.h5
*.ckpt
*.safetensors
*.onnx
*.pkl
*.bin

# Allow specific small model files (Exceptions)
!**/yolo/best.pt

# Re-ignore virtual environment and unnecessary files specifically
**/.venv/
**/__pycache__/
**/*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.cursor/
.vscode/
*.log
src/model5/test_img/
